# Cup2Cup Frontend Environment Variables

# API Backend URL
VITE_API_URL=http://localhost:3001

# Jitsi Meet Domain (leave empty to use public server meet.jit.si)
# Set this to your custom Jitsi domain after setting up your own server
# Example: VITE_JITSI_DOMAIN=meet.cup2cup.com
VITE_JITSI_DOMAIN=
